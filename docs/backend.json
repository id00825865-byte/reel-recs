
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user of the ReelRecs application.",
      "properties": {
        "id": {
          "type": "string"
        },
        "username": {
          "type": "string"
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "isAdmin": {
          "type": "boolean",
          "description": "True if the user has administrative privileges."
        },
        "status": {
          "type": "string",
          "enum": ["active", "banned"]
        },
        "lastLogin": {
          "type": "object"
        }
      },
      "required": [
        "id",
        "email"
      ]
    },
    "GlobalStats": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "GlobalStats",
      "type": "object",
      "description": "Daily global metrics for the application.",
      "properties": {
        "recommendationRequests": {
          "type": "number"
        }
      }
    },
    "UserWatchedMovie": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserWatchedMovie",
      "type": "object",
      "description": "A movie marked as watched by a user, including full metadata and star rating.",
      "properties": {
        "id": {
          "type": "string"
        },
        "userId": {
          "type": "string"
        },
        "movieId": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "posterUrl": {
          "type": "string"
        },
        "watchedAt": {
          "type": "string",
          "format": "date-time"
        },
        "rating": {
          "type": "number",
          "minimum": 1,
          "maximum": 5
        },
        "year": {
          "type": "string"
        },
        "imdbRating": {
          "type": "number"
        },
        "synopsis": {
          "type": "string"
        },
        "duration": {
          "type": "string"
        },
        "director": {
          "type": "string"
        },
        "actors": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "platforms": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "trailerUrl": {
          "type": "string",
          "format": "uri"
        }
      },
      "required": [
        "userId",
        "title",
        "watchedAt"
      ]
    },
    "WatchlistMovie": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "WatchlistMovie",
      "type": "object",
      "description": "A movie added to the user's 'to-watch' list with full metadata.",
      "properties": {
        "id": {
          "type": "string"
        },
        "userId": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "posterUrl": {
          "type": "string"
        },
        "addedAt": {
          "type": "string",
          "format": "date-time"
        },
        "year": {
          "type": "string"
        },
        "imdbRating": {
          "type": "number"
        },
        "synopsis": {
          "type": "string"
        },
        "duration": {
          "type": "string"
        },
        "director": {
          "type": "string"
        },
        "actors": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "platforms": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "trailerUrl": {
          "type": "string",
          "format": "uri"
        }
      },
      "required": [
        "userId",
        "title",
        "addedAt"
      ]
    }
  },
  "auth": {
    "providers": [
      "password"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": {
            "$ref": "#/backend/entities/User"
          }
        }
      },
      {
        "path": "/globalStats/{date}",
        "definition": {
          "entityName": "GlobalStats",
          "schema": {
            "$ref": "#/backend/entities/GlobalStats"
          }
        }
      },
      {
        "path": "/users/{userId}/watchedMovies/{watchedMovieId}",
        "definition": {
          "entityName": "UserWatchedMovie",
          "schema": {
            "$ref": "#/backend/entities/UserWatchedMovie"
          }
        }
      },
      {
        "path": "/users/{userId}/watchlist/{watchlistId}",
        "definition": {
          "entityName": "WatchlistMovie",
          "schema": {
            "$ref": "#/backend/entities/WatchlistMovie"
          }
        }
      }
    ]
  }
}
