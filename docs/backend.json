
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user of the ReelRecs application.",
      "properties": {
        "id": {
          "type": "string"
        },
        "username": {
          "type": "string"
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "email"
      ]
    },
    "Movie": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Movie",
      "type": "object",
      "description": "Core movie details used across the app.",
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "synopsis": {
          "type": "string"
        },
        "director": {
          "type": "string"
        },
        "actors": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "posterUrl": {
          "type": "string",
          "format": "uri"
        }
      },
      "required": [
        "title",
        "posterUrl"
      ]
    },
    "UserWatchedMovie": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserWatchedMovie",
      "type": "object",
      "description": "A movie marked as watched by a user, including an optional star rating.",
      "properties": {
        "id": {
          "type": "string"
        },
        "userId": {
          "type": "string"
        },
        "movieId": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "posterUrl": {
          "type": "string"
        },
        "watchedAt": {
          "type": "string",
          "format": "date-time"
        },
        "rating": {
          "type": "number",
          "description": "User rating from 1 to 5 stars.",
          "minimum": 1,
          "maximum": 5
        }
      },
      "required": [
        "userId",
        "title",
        "watchedAt"
      ]
    },
    "WatchlistMovie": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "WatchlistMovie",
      "type": "object",
      "description": "A movie added to the user's 'to-watch' list.",
      "properties": {
        "id": {
          "type": "string"
        },
        "userId": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "posterUrl": {
          "type": "string"
        },
        "addedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "userId",
        "title",
        "addedAt"
      ]
    }
  },
  "auth": {
    "providers": [
      "password"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": {
            "$ref": "#/backend/entities/User"
          }
        }
      },
      {
        "path": "/users/{userId}/watchedMovies/{watchedMovieId}",
        "definition": {
          "entityName": "UserWatchedMovie",
          "schema": {
            "$ref": "#/backend/entities/UserWatchedMovie"
          }
        }
      },
      {
        "path": "/users/{userId}/watchlist/{watchlistId}",
        "definition": {
          "entityName": "WatchlistMovie",
          "schema": {
            "$ref": "#/backend/entities/WatchlistMovie"
          }
        }
      }
    ]
  }
}
